{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/warm-players",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/sofascore",
      "schedule": "0 3 * * 1"
    },
    {
      "path": "/api/cron/ingest-results",
      "schedule": "0 4 * * *"
    }
  ]
}
